{
    "configurations": [
        {
            "name": "Test1 @MLWH",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test/test_all_img2eps.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}:${env:PYTHONPATH}"
            }
        },
        {
            "name": "[MLWH] 監視開始",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}:${env:PYTHONPATH}"
            },
        },
        {
            "name": "[MLWH] Python デバッガー: 現在のファイル",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}:${env:PYTHONPATH}"
            },
        },
        {
            "name": "Install by setup.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/setup.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "install"
            ]
        },
        {
            "name": "SDist by setup.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/setup.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "sdist"
            ]
        },
        {
            "name": "sample-start_watcher For PDF",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sample/start_watcher.py",
            "console": "integratedTerminal",
            "args": [
                "--ext",
                "pdf"
            ]
        },
        {
            "name": "sample-start_watcher For PNG",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sample/start_watcher.py",
            "console": "integratedTerminal",
            "args": [
                "--ext",
                "png"
            ]
        },
        {
            "name": "sample-start_watcher For EPS",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sample/start_watcher",
            "console": "integratedTerminal",
            "args": [
                "--ext",
                "eps"
            ]
        }
    ]
}